    ]
  },
  "distance_metrics": {
    "EUCLIDEAN": "dij = sqrt(sum((xil-xjl)^2))",
    "CITY_BLOCK": "dij = sum(abs(xil-xjl))",
    "MINKOWSKI": "dij = (sum(abs(xil-xjl)^r))^(1/r)"
  },
  "fit_functions": {
    "raw_stress": "S* = sum((dij-dhatij)^2)",
    "normalized_stress": "S = sqrt(sum((dij-dhatij)^2)/sum(dij^2))"
  },
  "distance_normalization": {
    "rule": "d_norm(i,j) = d_ij / d_max",
    "range": [
      0,
      1
    ]
  },
  "osgood_suboperation": {
    "graph_mapping": {
      "semantic_differential": "TG:FWPSY021",
      "semantic_space": "TG:FWPSY022",
      "epa_profile": "TG:CTPSY070",
      "distance_normalization": "TG:THMET083",
      "evaluation_axis": "TG:DMPSY001",
      "potency_axis": "TG:DMPSY002",
      "activity_axis": "TG:DMPSY003"
    },
    "score_range": [
      -3,
      3
    ],
    "input_handling": {
      "TEXT": "score directly from text",
      "IMAGE": "build semantic description then score",
      "FIGURE": "build semantic description then score",
      "LOGO": "build semantic description then score",
      "HYBRID_CORRECTION": "apply user corrections to auto-description before scoring"
    },
    "coordinates": "x = (e, p, a)",
    "raw_distance_rule": "D_raw = sqrt((e1-e2)^2 + (p1-p2)^2 + (a1-a2)^2)",
    "distance_corridor": {
      "D_min": 0,
      "D_max": 10.3923048454
    },
    "distance_normalization_rule": "D_norm = D_raw / 10.3923048454"
  },
  "alpha_estimation": {
    "graph_mapping": {
      "osgood_calibrated_alpha": "TG:THMET084",
      "alpha_estimation_from_generalization": "TG:THMET082"
    },
    "OSGOOD_CALIBRATED": {
      "corridor": [
        0.01,
        6.9078
      ],
      "delta_alpha": 6.8978,
      "rule": "alpha_raw_final = 0.01 + 6.8978 * D_norm",
      "justification_at_d_equals_1": {
        "alpha_min_output": "exp(-0.01) ≈ 0.99",
        "alpha_max_output": "exp(-6.9078) ≈ 0.001"
      }
    },
    "SINGLE_PAIR": {
      "rule": "alpha_raw_estimated = -ln(g) / d",
      "constraints": [
        "d > 0",
        "0 < g <= 1"
      ]
    },
    "MULTI_PAIR_FIT": {
      "rule": "fit ln(g_i) = -alpha_raw_estimated * d_i ; alpha_raw_estimated = -slope"
    },
    "EXPLICIT_ONLY": {
      "rule": "use user-provided alpha"
    },
    "bounding": {
      "HARD_BOUNDED": "estimate alpha only within [0.01, 6.9078]",
      "ESTIMATE_THEN_CLIP": "alpha_raw_final = max(0.01, min(alpha_raw_estimated, 6.9078))"
    },
    "normalization_rule": "alpha_norm = (alpha_raw_final - 0.01) / 6.8978",
    "denormalization_rule": "alpha_raw_final = 0.01 + 6.8978 * alpha_norm",
    "status_values": [
      "in_range",
      "clipped_low",
      "clipped_high"
    ]
  },
  "shepard_stage": {
    "graph_mapping": {
      "exponential_decay_of_generalization": "TG:THPSY200",
      "shepard_generalization_function": "TG:THMET081"
    },
    "distance_input_modes": [
      "SCALE_DISTANCE",
      "AGGREGATED_DISTANCE",
      "MDS_RECOVERED_DISTANCE",
      "OSGOOD_DISTANCE"
    ],
    "formula": "g(d) = exp(-alpha_raw_final * d_norm)",
    "note": "when OSGOOD_DISTANCE is selected, d_norm = D_norm"
  },
  "constraints": {
    "diagonal_zero": true,
    "symmetric_matrix": true,
    "cross_modal_requires_shared_space": true,
    "automatic_imputation_allowed": false,
    "hidden_metric_switching_allowed": false,
